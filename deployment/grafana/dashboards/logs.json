{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{service=~\".+\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    },
    {
      "title": "API Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{service=\"api\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Worker Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{service=\"worker\"}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Logs",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "" },
          "expr": "{service=~\".+\"} |~ \"error|Error|ERROR|level.*50\"",
          "refId": "A"
        }
      ]
    }
  ],
