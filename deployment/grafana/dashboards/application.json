{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active Games",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eyeonchess_active_games",
          "legendFormat": "active"
        }
      ]
    },
    {
      "title": "Total Users",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "blue", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "eyeonchess_total_users",
          "legendFormat": "users"
        }
      ]
    },
    {
      "title": "Analysis Queue",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "eyeonchess_analysis_queue_depth",
          "legendFormat": "queued"
        }
      ]
    },
    {
      "title": "Games Completed",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [{ "color": "purple", "value": null }]
          }
        }
      },
      "targets": [
        {
          "expr": "eyeonchess_games_completed_total",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": "Active Games Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "expr": "eyeonchess_active_games",
          "legendFormat": "active games"
        }
      ]
    },
    {
      "title": "Games Completed Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "expr": "rate(eyeonchess_games_completed_total[5m]) * 60",
          "legendFormat": "games/min"
        }
      ]
    },
    {
      "title": "Analysis Queue Depth Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "fillOpacity": 20,
            "lineWidth": 2
          },
          "color": { "fixedColor": "orange", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "eyeonchess_analysis_queue_depth",
          "legendFormat": "queue depth"
        }
      ]
    },
    {
      "title": "User Growth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "eyeonchess_total_users",
          "legendFormat": "total users"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["eyeonchess", "application"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "EyeOnChess - Application",
  "uid": "eyeonchess-app"
}
